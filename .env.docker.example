# --- Docker Compose ortam degiskenleri (KOK .env) ---
# Bu dosya `docker compose` tarafindan okunur. Gercek `.env` kurulum
# script'i (scripts/install.sh) tarafindan rastgele sirlarla uretilir.
# Uretim sirlarini bu ornek dosyaya KOYMAYIN.

# Host'ta API'nin yayinlanacagi port
API_PORT=3000

# API container'i ic ayarlari
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# PostgreSQL (db servisi)
POSTGRES_USER=community
POSTGRES_PASSWORD=change-me
POSTGRES_DB=community

# Uygulama veritabani baglantisi (host = docker servis adi: db)
DATABASE_URL=postgresql://community:change-me@db:5432/community

# JWT
JWT_SECRET=change-me-with-a-long-random-secret
JWT_ISSUER=oserp-community

# Migration SQL klasoru (imaj icindeki yol)
IAM_MIGRATIONS_DIR=/app/packages/iam/drizzle
