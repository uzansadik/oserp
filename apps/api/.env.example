# --- apps/api ortam değişkenleri (örnek) ---
# `.env` olarak kopyalayın ve değerleri ortamınıza göre doldurun.

# Sunucu
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# PostgreSQL bağlantısı (kullanıcı:parola@host:port/veritabani)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/community

# JWT imzalama anahtarı (zorunlu)
JWT_SECRET=

# JWT issuer (opsiyonel)
JWT_ISSUER=oserp-community
